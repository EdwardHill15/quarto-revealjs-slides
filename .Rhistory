geom_violin(alpha = 0.5, trim = FALSE) +
geom_boxplot(
width = 0.15,
alpha = 0.8,
outlier.shape = 16
) +
scale_fill_manual(
values = c(
"low" = "blue",
"mid" = "green",
"high" = "red"
)
) +
labs(
x = "Avidya",
y = "Neuroticism",
title = "Neuroticism by Avidya Level"
) +
theme_minimal() +
facet_wrap(~gender)
