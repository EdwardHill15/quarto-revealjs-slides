dt |>
select(c(2:10,19)) |>
mutate(avidya = factor(avidya, levels = c("low", "mid", "high"))) |>
ggplot(aes(x=negativism,y=anxiety, fill=avidya, col = avidya)) +
geom_point(size = 6, alpha=0.7) +
scale_color_manual(
values=c(
"low" = "blue",
"mid" = "green",
"high" = "red"
)
) +
#geom_smooth(method = "lm", se = TRUE) +
labs(
x = "negativsism",
y = "anxiety",
title = "Linear regressgion Plot"
) +
theme_minimal() +
facet_wrap(.~gender)
