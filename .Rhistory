library(stringr)
base_url <- "https://quotes.toscrape.com"
scrape_page <- function(url) {
page <- read_html(url)
quote_nodes <- html_elements(page, ".quote")
if (length(quote_nodes) == 0) {
return(NULL)
}
quotes <- quote_nodes |>
html_element(".text") |>
html_text2()
authors <- quote_nodes |>
html_element(".author") |>
html_text2()
tags <- quote_nodes |>
map_chr(~ {
.x |>
html_elements(".tag") |>
html_text2() |>
paste(collapse = ", ")
})
data.frame(
Quote = quotes,
Author = authors,
Tags = tags,
stringsAsFactors = FALSE
)
}
# Scrape all pages
all_quotes <- list()
url <- base_url
while(TRUE) {
cat("Scraping:", url, "\n")
df <- scrape_page(url)
if (!is.null(df)) {
all_quotes[[length(all_quotes) + 1]] <- df
}
page <- read_html(url)
next_link <- page |>
html_element(".next a")
if (is.na(next_link)) break
href <- html_attr(next_link, "href")
if (is.na(href)) break
url <- paste0(base_url, href)
}
quotes_df <- bind_rows(all_quotes)
head(quotes_df)
